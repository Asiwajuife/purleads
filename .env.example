# ─────────────────────────────────────────────────────────────────────────────
# Purleads — Environment Variables
# Copy this file to .env (root), apps/api/.env, and apps/worker/.env
# Set NEXT_PUBLIC_API_URL in apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Both URLs point to the same Neon DB. DIRECT_URL bypasses the connection
# pooler and is required by Prisma for migrations/schema push.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Redis (Upstash recommended) ─────────────────────────────────────────────
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true   # set to "true" for Upstash and most cloud Redis providers

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── API ──────────────────────────────────────────────────────────────────────
# API_PORT is the fallback. Railway injects PORT automatically — do not set PORT manually.
API_PORT=3001

# Public URL of the deployed API (no trailing slash).
# Used by the worker to build tracking-pixel and unsubscribe URLs in emails.
API_URL=https://your-api.railway.app

# Allowed CORS origin — set to your Vercel frontend URL in production.
FRONTEND_URL=https://your-app.vercel.app

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Must be set at BUILD TIME on Vercel (not just runtime).
# The web app calls this URL directly from the browser.
NEXT_PUBLIC_API_URL=https://your-api.railway.app

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used by the worker to generate AI icebreakers for cold emails.
OPENAI_API_KEY=sk-your-openai-api-key

# ─── System SMTP (optional) ───────────────────────────────────────────────────
# Per-inbox SMTP credentials are stored in the database (not here).
# These are only needed if you add a system-level mailer in the future.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# ─── Calendly ─────────────────────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/your-link

# ─── Lead Enrichment Providers (worker only) ──────────────────────────────────
# Set these in apps/worker/.env — the worker reads them directly.
# Apollo.io: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Snov.io: https://app.snov.io/account?settings=api
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
